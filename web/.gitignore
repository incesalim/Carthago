# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# OpenNext build output
/.open-next/

# Wrangler local state
/.wrangler/

# web/migrations/ holds hand-authored schema migrations — TRACKED (source of truth).
# Generated DATA seed dumps (scripts/generate_d1_migrations.py) go to web/seeds/ — ignored.
/seeds/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
