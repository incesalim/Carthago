# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/

# But the Next.js app's lib/ folder is needed (path-alias source)
!web/app/lib/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebook
.ipynb_checkpoints

# Data files
data/raw/**/*.csv
data/raw/**/*.xlsx
data/processed/**/*.csv
data/processed/**/*.xlsx
*.db
*.sqlite
*.sqlite3
# Compressed DB snapshots now live in R2 (state/*.db.gz); never commit them.
data/bddk_data.db.gz
data/bank_audit.db.gz

# External reports — third-party PDFs, do not redistribute
data/external_reports/

# EVDS HTTP response cache (rebuilt on demand)
data/evds_cache/

# Per-bank audit-report PDFs — 2 GB+ of bank-published PDFs.
# Kept local only; structured rows live in bddk_data.db (bank_audit_* tables).
# URL config IS committed (data/banks/audit_report_urls.json) so the pipeline
# is reproducible from scratch.
data/audit_reports/

# Auto-generated catalogue (regenerated by a scraper probe)
scripts/_weekly_catalogue.json

# Reports
reports/**/*.pdf
reports/**/*.html
reports/**/*.xlsx

# Logs
logs/**/*.log
data/_*.log
data/_tmp_*.pdf

# Environment variables
.env
.env.local

# System files
Thumbs.db
.DS_Store

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Chrome driver
chromedriver
chromedriver.exe

# Backup files
*.bak
*.bak-*
*.backup
bddk_data.db.bak*

# Keep directory structure but ignore contents
!data/raw/.gitkeep
!data/processed/.gitkeep
!reports/.gitkeep
!logs/.gitkeep

# Agent / scratch work (not versioned)
_scratch/

# Claude Code local state — per-user, never committed
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# Next.js / Cloudflare / OpenNext local build artefacts (not versioned)
.next/
.wrangler/
.open-next/
.dev.vars
# Migration log from one-shot migrate_pdfs_to_r2.py runs
migrate.log


# Local pipeline run logs
data/*.log
