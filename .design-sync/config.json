{
  "projectId": "45ee1550-6151-41fb-b5f8-da2e1eff1568",
  "shape": "package",
  "pkg": "web",
  "globalName": "BDDKUI",
  "entry": "web/.ds-dist/app/components/ui/index.js",
  "srcDir": "app/components/ui",
  "tsconfig": "tsconfig.json",
  "cssEntry": ".ds-dist/ds.css",
  "extraFonts": ["../.design-sync/fonts/geist.css"],
  "buildCmd": "cd web && npx tsc -p tsconfig.ds.json && npx @tailwindcss/cli -i ../.design-sync/ds-css-entry.css -o .ds-dist/ds.css",
  "provider": {
    "component": "ThemeProvider",
    "props": { "attribute": "class", "defaultTheme": "light", "enableSystem": false }
  }
}
